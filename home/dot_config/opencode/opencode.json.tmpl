{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "plugin": ["@mohak34/opencode-notifier@latest"],
    "mcp": {
        "web-search-prime": {
            "type": "remote",
            "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
            "headers": {
                "Authorization": "Bearer {{ onepasswordRead "op://Personal/Z/API Keys/claude-code" }}"
            }
        },
        "web-reader": {
            "type": "remote",
            "url": "https://api.z.ai/api/mcp/web_reader/mcp",
            "headers": {
                "Authorization": "Bearer {{ onepasswordRead "op://Personal/Z/API Keys/claude-code" }}"
            }
        },
        "zai-mcp-server": {
            "type": "local",
            "command": ["npx", "-y", "@z_ai/mcp-server"],
            "environment": {
                "Z_AI_API_KEY": "{{ onepasswordRead "op://Personal/Z/API Keys/claude-code" }}",
                "Z_AI_MODE": "ZAI"
            }
        },
        "dash-mcp-server": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/Kapeli/dash-mcp-server.git",
                "dash-mcp-server"
            ]
        },
        "emacs": {
            "type": "local",
            "command": [
                "uv",
                "--directory",
                "/Users/jesse/src/github.com/jesse-c/emacs-mcp-server",
                "run",
                "emacs-mcp-server"
            ]
        },
        "cua": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "cua-cli[mcp]",
                "cua",
                "serve-mcp"
            ]
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@playwright/mcp@latest"
            ]
        },
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "headers": {}
        },
        "tavily": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "tavily-mcp@latest"
            ]
        },

    },
    "provider": {
        "lmstudio": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "LM Studio (local)",
        "options": { "baseURL": "http://127.0.0.1:1234/v1" },
        "models": {
                "google/gemma-4-26b-a4b": { "name": "Gemma 4 26B" },
                "qwen/qwen3.6-27b": { "name": "Qwen3.6 27B" }
            }
        }
    }
}
