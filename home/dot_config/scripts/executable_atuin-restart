#!/usr/bin/env bash
pid_file="$HOME/.local/share/atuin/atuin-daemon.pid"
sock_file="$HOME/.local/share/atuin/atuin.sock"

if [ -f "$pid_file" ]; then
    pid=$(head -1 "$pid_file")
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        echo "Stopped atuin daemon (PID $pid)"
    else
        echo "Stale PID file ($pid) — cleaning up"
    fi
    rm -f "$pid_file"
fi

rm -f "$sock_file"

atuin daemon start &
disown
echo "atuin daemon started"
