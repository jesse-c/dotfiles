[env]
NODE_OPTIONS = "--no-deprecation"
# gcloud's bootstrap defaults to system python3 (3.9), which is unsupported and
# fails to import urllib3. Pin it to mise's python 3.12 (always installed).
CLOUDSDK_PYTHON = "{{ .chezmoi.homeDir }}/.local/share/mise/installs/python/3.12/bin/python3"
{{ if eq .chezmoi.hostname "Plinth" }}
SCHEME = "racket"
{{ else if eq .chezmoi.hostname "Dais" }}
PHP_CONFIGURE_OPTIONS = "--with-openssl=/opt/homebrew/opt/openssl@3"
PKG_CONFIG_PATH = "/opt/homebrew/opt/openssl@3/lib/pkgconfig:/opt/homebrew/opt/icu4c@78/lib/pkgconfig:/opt/homebrew/opt/libxml2/lib/pkgconfig:/opt/homebrew/opt/libzip/lib/pkgconfig:/opt/homebrew/opt/curl/lib/pkgconfig:/opt/homebrew/opt/gd/lib/pkgconfig:/opt/homebrew/opt/oniguruma/lib/pkgconfig:/opt/homebrew/opt/zlib/lib/pkgconfig:/opt/homebrew/opt/libpq/lib/pkgconfig"
CPPFLAGS = "-I/opt/homebrew/opt/openssl@3/include"
LDFLAGS = "-L/opt/homebrew/opt/openssl@3/lib"
{{ end }}


